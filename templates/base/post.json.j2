{
  "@context": "https://www.w3.org/ns/activitystreams",
  "type": "{{ post_type }}",
  "id": "{{ website_url }}/{{ namespace }}/posts/{{ post_id }}",
  "url": "{{ post_url }}",
  "attributedTo": "{{ website_url }}/{{ namespace }}/actor",
  "published": "{{ published }}"{% if updated %},
  "updated": "{{ updated }}"{% endif %}{% if title %},
  "name": "{{ title }}"{% endif %}{% if content %},
  "content": "{{ content }}"{% endif %}{% if summary %},
  "summary": "{{ summary }}"{% endif %},
  "likes": {"type": "OrderedCollection", "id": "{{ website_url }}/{{ namespace }}/posts/{{ post_id }}/likes", "totalItems": 0},
  "shares": {"type": "OrderedCollection", "id": "{{ website_url }}/{{ namespace }}/posts/{{ post_id }}/shares", "totalItems": 0},
  "replies": {"type": "OrderedCollection", "id": "{{ website_url }}/{{ namespace }}/posts/{{ post_id }}/replies", "totalItems": 0}
}